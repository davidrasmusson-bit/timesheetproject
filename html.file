<style>
:root{--blue:#2E62D9;--bdim:rgba(46,98,217,0.07);--tx:#0d0d14;--t2:#2d3748;--t3:#5a6a82;--br:#e2e6ef;--b2:#c8d0df;--s1:#f7f8fa;--grn:#16a34a;}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:#fff;color:var(--tx);overflow:hidden;}
#root{position:fixed;inset:0;display:grid;grid-template-columns:1fr 1fr;}
.left{display:flex;flex-direction:column;justify-content:center;padding:64px 52px;border-right:1px solid var(--br);}
.right{display:flex;flex-direction:column;justify-content:center;padding:64px 52px;background:var(--s1);}
.eye{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.eye::before{content:'';width:24px;height:2px;background:var(--blue);}
h1{font-family:'DM Serif Display',serif;font-size:clamp(24px,3vw,38px);line-height:1.05;margin-bottom:14px;}
