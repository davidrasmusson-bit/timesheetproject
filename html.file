<style>
:root{--blue:#2E62D9;--bdim:rgba(46,98,217,0.08);--tx:#0d0d14;--t2:#2d3748;--t3:#5a6a82;--br:#e2e6ef;--b2:#c8d0df;--s1:#f7f8fa;--red:#c41a1a;--grn:#16a34a;--amb:#c97a00;}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;background:#fff;}
body{font-family:"DM Sans",sans-serif;color:var(--tx);}
#mnav{position:fixed;top:0;left:0;right:0;z-index:9999;height:48px;background:rgba(255,255,255,.97);border-bottom:1px solid var(--br);display:flex;align-items:center;padding:0 20px;backdrop-filter:blur(16px);}
.nbrand{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--t3);margin-right:20px;display:flex;align-items:center;gap:8px;flex-shrink:0;}
.nbrand-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);}
.ntabs{display:flex;gap:2px;flex:1;overflow-x:auto;}
.ntabs::-webkit-scrollbar{display:none;}
.ntab{padding:6px 13px;border-radius:5px;font-size:11px;font-weight:500;color:var(--t3);cursor:pointer;border:none;background:none;font-family:"DM Sans",sans-serif;transition:all .2s;white-space:nowrap;flex-shrink:0;}
.ntab:hover{color:var(--t2);background:var(--s1);}
.ntab.active{color:var(--blue);background:var(--bdim);font-weight:600;}
#mpb{position:fixed;top:48px;left:0;right:0;height:2px;z-index:9998;}
#mpbf{height:100%;background:linear-gradient(90deg,var(--blue),#6fa3f5);transition:width .4s cubic-bezier(.4,0,.2,1);}
#ifl{position:fixed;top:50px;left:0;right:0;bottom:0;}
.sframe{position:absolute;inset:0;border:none;width:100%;height:100%;display:none;}
.sframe.active{display:block;}
</style>
</head>
<body>
<nav id="mnav">
