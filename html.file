<script>
var cur=0,N=7;
var pcts=['14%','28%','42%','57%','71%','85%','100%'];
function sw(n){
  if(n===cur)return;
  document.getElementById('sf-'+cur).classList.remove('active');
  document.querySelectorAll('.ntab')[cur].classList.remove('active');
  cur=n;
  document.getElementById('sf-'+cur).classList.add('active');
  document.querySelectorAll('.ntab')[cur].classList.add('active');
  document.getElementById('mpbf').style.width=pcts[cur];
}
document.addEventListener('keydown',function(e){
  if(e.shiftKey&&e.key==='ArrowRight'){e.preventDefault();sw(Math.min(cur+1,N-1));}
  if(e.shiftKey&&e.key==='ArrowLeft'){e.preventDefault();sw(Math.max(cur-1,0));}
});

// Build Solution Breakdown slide
(function(){
  var s=document.getElementById('sf-3');
  s.innerHTML='<style>@import url("https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap");*{margin:0;padding:0;box-sizing:border-box;}html,body{height:100%;font-family:"DM Sans",sans-serif;background:#fff;color:#0d0d14;overflow-y:auto;}.w{max-width:1060px;margin:0 auto;padding:68px 60px 80px;}.eye{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#2E62D9;margin-bottom:10px;display:flex;align-items:center;gap:10px;}.eye::before{content:"";width:24px;height:2px;background:#2E62D9;display:block;}h1{font-family:"DM Serif Display",serif;font-size:clamp(26px,3.2vw,40px);line-height:1.05;margin-bottom:6px;}h1 em{font-style:italic;color:#2E62D9;}.sub{font-size:13px;color:#5a6a82;max-width:680px;line-height:1.75;margin-bottom:20px;}.opts{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}.opt{border-radius:14px;overflow:hidden;border:1px solid #e2e6ef;display:flex;flex-direction:column;}.opt.rec{border-color:rgba(46,98,217,.4);box-shadow:0 4px 24px rgba(46,98,217,.12);}.opt-head{padding:18px 20px;}.opt-tag{font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}.opt-name{font-family:"DM Serif Display",serif;font-size:20px;line-height:1.1;margin-bottom:5px;}.opt-desc{font-size:11.5px;color:rgba(255,255,255,.6);line-height:1.6;}.opt-body{padding:16px 20px;background:#fff;flex:1;display:flex;flex-direction:column;}.opt-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(0,0,0,.05);gap:10px;}.opt-row:last-child{border-bottom:none;}.or-label{font-size:11px;color:#5a6a82;}.or-val{font-size:11px;font-weight:700;}.chk{color:#16a34a;}.crs{color:#e2e6ef;}.diff-section{background:#f7f8fa;border:1px solid #e2e6ef;border-radius:14px;padding:20px 24px;}.diff-title{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#5a6a82;margin-bottom:14px;}.diff-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}.diff-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#5a6a82;margin-bottom:8px;}.diff-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(0,0,0,.05);}.diff-row:last-child{border-bottom:none;}.diff-k{font-size:11.5px;color:#5a6a82;}.diff-b{font-size:11.5px;font-weight:700;color:#c41a1a;}.diff-a{font-size:11.5px;font-weight:700;color:#16a34a;}</style><div class="w"><div class="eye">Solution Breakdown</div><h1>Choose how far<br><em>you want to go.</em></h1><p class="sub">Each option includes everything in the one before it. Foundation works on its own from day one. Foundation + Intelligence is the recommended path. Full Suite adds employer certificate automation on top.</p><div class="opts"><div class="opt"><div class="opt-head" style="background:#2d3748;"><div class="opt-tag" style="color:rgba(255,255,255,.5);">Starting point</div><div class="opt-name" style="color:#fff;">Foundation</div><div class="opt-desc">Reads all 25 client formats &mdash; Excel, PDF, JPEG, scanned paper &mdash; and normalises them into a clean standardised file the ops team can import into Recman in one click.</div></div><div class="opt-body"><div class="opt-row"><span class="or-label">Manual work eliminated</span><span class="or-val" style="color:#16a34a;">~70%</span></div><div class="opt-row"><span class="or-label">Document extraction (25 formats)</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Format normalization profiles</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Gap-fill agent via Recman API</span><span class="or-val crs">✗</span></div><div class="opt-row"><span class="or-label">Automated Recman import</span><span class="or-val crs">✗</span></div><div class="opt-row"><span class="or-label">Exception review UI</span><span class="or-val crs">✗</span></div><div class="opt-row"><span class="or-label">Employer certificate module</span><span class="or-val crs">✗</span></div></div></div><div class="opt rec"><div class="opt-head" style="background:#2E62D9;"><div class="opt-tag" style="color:rgba(255,255,255,.7);">Recommended</div><div class="opt-name" style="color:#fff;">Foundation + Intelligence</div><div class="opt-desc">Full automation. Gap-fill agent infers missing fields. Records written to Recman. 1,000+ timesheets automated.</div></div><div class="opt-body"><div class="opt-row"><span class="or-label">Manual work eliminated</span><span class="or-val" style="color:#16a34a;">~90%</span></div><div class="opt-row"><span class="or-label">Document extraction (25 formats)</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Format normalization profiles</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Gap-fill agent via Recman API</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Automated Recman import</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Exception review UI</span><span class="or-val chk">✓</span></div><div class="opt-row"><span class="or-label">Employer certificate module</span><span class="or-val crs">✗</span></div></div></div><div class="opt"><div class="opt-head" style="background:#0d7c4f;"><div class="opt-tag" style="color:rgba(255,255,255,.5);">Full automation</div><div class="opt-name" style="color:#fff;">Full Suite</div><div class="opt-desc">Everything in Foundation + Intelligence plus automatic employer certificate generation.</div></div><div class="opt-body"><div class="opt-row"><span class="or-label">Manual work eliminated</span><span class="or-val" style="color:#16a34a;">~98%</span></div><div class="opt-row"><span class="or-label">Document extraction (25 formats)</span><span class="or-