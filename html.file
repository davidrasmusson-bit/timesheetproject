.mi{display:flex;justify-content:space-between;align-items:center;padding:11px 16px;border-bottom:1px solid var(--br);}
.mi:last-child{border-bottom:none;}
.ml{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--b2);}
.mv{font-size:13px;font-weight:600;color:var(--t2);}
.mv.hl{color:var(--blue);font-family:'DM Serif Display',serif;font-size:16px;}
.mark{position:absolute;bottom:20px;left:60px;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--b2);}
.stats{position:relative;z-index:1;display:flex;flex-direction:column;gap:14px;}
.stat{background:#fff;border:1px solid var(--br);border-radius:12px;padding:20px 24px;border-left:3px solid var(--blue);box-shadow:0 1px 3px rgba(14,20,45,.06),0 4px 16px rgba(14,20,45,.04);}
.sn{font-family:'DM Serif Display',serif;font-size:42px;color:var(--blue);line-height:1;margin-bottom:4px;}
.sl{font-size:12px;color:var(--t3);line-height:1.5;}
.ss{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--b2);margin-top:5px;text-transform:uppercase;letter-spacing:.12em;}
@keyframes fu{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
.a{opacity:0;animation:fu .6s cubic-bezier(.4,0,.2,1) forwards;}
.d1{animation-delay:.08s;}.d2{animation-delay:.2s;}.d3{animation-delay:.34s;}.d4{animation-delay:.48s;}.d5{animation-delay:.62s;}
</style></head><body>
