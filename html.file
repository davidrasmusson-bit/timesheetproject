(function(){
  var s=document.getElementById('sf-4');
  s.innerHTML='<style>@import url("https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap");*{margin:0;padding:0;box-sizing:border-box;}html,body{height:100%;font-family:"DM Sans",sans-serif;background:#fff;color:#0d0d14;overflow-y:auto;}.w{max-width:1060px;margin:0 auto;padding:68px 60px 80px;}.eye{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#2E62D9;margin-bottom:10px;display:flex;align-items:center;gap:10px;}.eye::before{content:"";width:24px;height:2px;background:#2E62D9;display:block;}h1{font-family:"DM Serif Display",serif;font-size:clamp(26px,3.2vw,40px);line-height:1.05;margin-bottom:6px;}h1 em{font-style:italic;color:#2E62D9;}.sub{font-size:13px;color:#5a6a82;max-width:680px;line-height:1.75;margin-bottom:22px;}.est-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}.est{border-radius:14px;overflow:hidden;border:1px solid #e2e6ef;}.est.rec{border-color:rgba(46,98,217,.4);box-shadow:0 4px 24px rgba(46,98,217,.12);}.est-head{padding:16px 20px;}.est-name{font-family:"DM Serif Display",serif;font-size:18px;color:#fff;margin-bottom:4px;}.est-tag{font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.5);}.est-body{padding:18px 20px;background:#fff;display:flex;flex-direction:column;gap:10px;}.est-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(0,0,0,.05);}.est-row:last-child{border-bottom:none;}.est-k{font-size:12px;color:#5a6a82;}.est-v{font-size:12px;font-weight:700;color:#0d0d14;font-family:"JetBrains Mono",monospace;}.est-price{font-family:"DM Serif Display",serif;font-size:26px;color:#2E62D9;margin-top:4px;line-height:1;}.est-note{font-size:10px;color:#8896a8;margin-top:4px;}.roi-box{background:#0d0d14;border-radius:14px;padding:24px 28px;display:grid;grid-template-columns:1.2fr 1fr;gap:32px;align-items:center;}.roi-left{}.roi-eye{font-size:9px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(111,163,245,.7);margin-bottom:8px;}.roi-title{font-family:"DM Serif Display",serif;font-size:22px;color:#fff;line-height:1.2;margin-bottom:12px;}.roi-title em{font-style:italic;color:#6fa3f5;}.roi-calc{display:flex;flex-direction:column;gap:6px;}.roi-line{display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,.05);}.roi-line.hl{background:rgba(46,98,217,.25);}.roi-k{font-size:12px;color:rgba(255,255,255,.5);}.roi-line.hl .roi-k{color:rgba(255,255,255,.8);font-weight:600;}.roi-v{font-size:12px;font-weight:700;color:#6fa3f5;font-family:"JetBrains Mono",monospace;}.roi-line.hl .roi-v{color:#fff;font-size:14px;}.roi-right{display:grid;grid-template-columns:1fr 1fr;gap:10px;}.roi-stat{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:14px;text-align:center;}.roi-stat.hl{background:rgba(46,98,217,.2);border-color:rgba(46,98,217,.4);}.rs-n{font-family:"DM Serif Display",serif;font-size:30px;color:#6fa3f5;line-height:1;margin-bottom:4px;}.roi-stat.hl .rs-n{color:#fff;}.rs-l{font-size:10px;color:rgba(255,255,255,.4);line-height:1.5;}.roi-stat.hl .rs-l{color:rgba(255,255,255,.6);}</style><div class="w"><div class="eye">Estimation</div><h1>Timeline, investment<br><em>and return.</em></h1><p class="sub">Indicative figures. Foundation is a fixed fee confirmed at this meeting. Foundation + Intelligence and Full Suite are confirmed after Recman API documentation is reviewed.</p><div class="est-grid"><div class="est"><div class="est-head" style="background:#2d3748;"><div class="est-tag">Starting point</div><div class="est-name">Foundation</div></div><div class="est-body"><div class="est-row"><span class="est-k">Timeline</span><span class="est-v">4&ndash;6 weeks</span></div><div class="est-row"><span class="est-k">Manual work eliminated</span><span class="est-v" style="color:#16a34a;">~70%</span></div><div class="est-row"><span class="est-k">Timesheets automated</span><span class="est-v">~70%</span></div><div class="est-price">200,000&ndash;250,000 <span style="font-size:14px;font-family:DM Sans,sans-serif;">SEK</span></div><div class="est-note"></div></div></div><div class="est rec"><div class="est-head" style="background:#2E62D9;"><div class="est-tag" style="color:rgba(255,255,255,.8);">Recommended</div><div class="est-name">Foundation + Intelligence</div></div><div class="est-body"><div class="est-row"><span class="est-k">Timeline</span><span class="est-v">7&ndash;10 weeks</span></div><div class="est-row"><span class="est-k">Manual work eliminated</span><span class="est-v" style="color:#16a34a;">~90%</span></div><div class="est-row"><span class="est-k">Timesheets automated</span><span class="est-v">~90–98%</span></div><div class="est-price">350,000&ndash;430,000 <span style="font-size:14px;font-family:DM Sans,sans-serif;">SEK</span></div><div class="est-note">Indicative &middot; confirmed after Recman API review</div></div></div><div class="est"><div class="est-head" style="background:#0d7c4f;"><div class="est-tag">Full automation</div><div class="est-name">Full Suite</div></div><div class="est-body"><div class="est-row"><span class="est-k">Timeline</span><span class="est-v">12&ndash;16 weeks</span></div><div class="est-row"><span class="est-k">Manual work eliminated</span><span class="est-v" style="color:#16a34a;">~98%</span></div><div class="est-row"><span class="est-k">Timesheets automated</span><span class="est-v">~90–98%</span></div><div class="est-price">600,000&ndash;660,000 <span style="font-size:14px;font-family:DM Sans,sans-serif;">SEK</span></div><div class="est-note">Contingent on Visma Spiris API access</div></div></div></div><div class="roi-box"><div class="roi-left"><div class="roi-eye">Return on Investment &mdash; Foundation + Intelligence</div><d