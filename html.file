<script>
function cnt(id,t,p,s,d){var el=document.getElementById(id);if(!el)return;var st=null;function step(ts){if(!st)st=ts;var pr=Math.min((ts-st)/d,1);var e=1-Math.pow(1-pr,3);el.textContent=p+Math.round(e*t)+s;if(pr<1)requestAnimationFrame(step);}setTimeout(function(){requestAnimationFrame(step);},700);}
cnt('s1',1000,'','',1400);cnt('s2',237,'','',1100);
</script>
